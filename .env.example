# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration (Sequelize will prioritize DATABASE_URL if provided)
# DATABASE_URL=mysql://user:password@host:port/database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=github_analyzer

# GitHub API Configuration (Optional but highly recommended to avoid 60 req/hr limit)
# Generate a token at https://github.com/settings/tokens
GITHUB_TOKEN=
